# Copy to .env.local for local dev, and set in Vercel for production.

# Scheduler lead delivery. When set, appointment requests are POSTed as JSON to
# this webhook (see src/app/actions.ts -> deliverLead). When unset, leads are
# only logged server-side. Swap in an email send (e.g. Resend) if preferred.
LEAD_WEBHOOK_URL=
